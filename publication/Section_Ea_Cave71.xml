                                            <cell n="4">行數</cell>
                                            <cell n="4">65+2</cell>
                                        </row>
                                        <row>
                                            <cell n="1">十行寬度</cell>
                                            <cell n="1">20.5至21.5厘米</cell>
                                        </row>
                                        <row>
                                            <cell>行距</cell>
                                            <cell>0.1至1.4厘米</cell>
                                        </row>
                                    </table>
                                </cell>
                            </row>
                            <row>
                                <cell>
                                    <table rend="innerboxSecond">
                                        <head>文字</head>
                                        <row>
                                            <cell>每行字數</cell>
                                            <cell>平均84字： 第10行83字，第17行87字</cell>
                                        </row>
                                        <row>
                                            <cell n="2">十字高度</cell>
                                            <cell n="2">21厘米</cell>
                                        </row>
                                        <row>
                                            <cell>字距</cell>
                                            <cell>0.1至1.5厘米</cell>
                                        </row>
                                    </table>
                                </cell>
                            </row>
                            <row>
                                <cell>
                                    <table rend="innerbox">
                                        <head>          舉例</head>
                                        <row n="1">
                                            <cell n="1">刻字</cell>
                                            <cell>行/字</cell>
                                            <cell n="1">高（厘米）</cell>
                                            <cell n="1">寬（厘米）</cell>
                                        </row>
                                        <row>
                                            <cell n="2">利</cell>
                                            <cell n="2">62/51</cell>
                                            <cell n="2">2.0</cell>
                                            <cell n="2">1.9</cell>
                                        </row>
